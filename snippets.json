  "ReadGrid": {
    "prefix": "grid",
    "body": [
      "int n, m; cin >> n >> m;",
      "vector<string> grid(n);",
      "for (auto& row : grid) cin >> row;",
      "",
      "// 4-directional movement",
      "int dx[] = {0,0,1,-1};",
      "int dy[] = {1,-1,0,0};",
      "",
      "auto valid = [&](int x, int y) {",
      "    return x >= 0 && x < n && y >= 0 && y < m;",
      "};"
    ],
