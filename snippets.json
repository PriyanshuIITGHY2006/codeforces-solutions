  "InversionCount": {
    "prefix": "inversions",
    "body": [
      "ll merge_count(vi& a, int l, int r) {",
      "    if (r - l <= 1) return 0;",
      "    int mid = (l + r) / 2;",
      "    ll cnt = merge_count(a, l, mid) + merge_count(a, mid, r);",
      "    vi tmp;",
      "    int i = l, j = mid;",
      "    while (i < mid && j < r) {",
      "        if (a[i] <= a[j]) tmp.push_back(a[i++]);",
      "        else { cnt += mid - i; tmp.push_back(a[j++]); }",
      "    }",
      "    while (i < mid) tmp.push_back(a[i++]);",
      "    while (j < r)   tmp.push_back(a[j++]);",
      "    for (int k = l; k < r; k++) a[k] = tmp[k-l];",
      "    return cnt;",
      "}"
    ],
    "description": "Inversion Count (Merge Sort)"
  },
  "TwoPointers": {
    "prefix": "twoptr",
    "body": [
      "int l = 0, r = 0;",
      "ll window = 0;",
      "ll ans = 0;",
      "while (r < n) {",
      "    window += a[r++];",
      "    while (window > ${1:target}) window -= a[l++];",
      "    ans = max(ans, (ll)(r - l));",
      "}"
    ],
    "description": "Two Pointers / Sliding Window"
  },
  "PrefixSum": {
    "prefix": "prefix",
    "body": [
      "vll pre(n + 1, 0);",
      "for (int i = 0; i < n; i++) pre[i+1] = pre[i] + a[i];",
      "// sum of [l, r] (0-indexed): pre[r+1] - pre[l]"
    ],
    "description": "Prefix Sum Array"
  },
  "PrefixSum2D": {
    "prefix": "prefix2d",
    "body": [
      "// 2D prefix sum (1-indexed)",
      "vector<vll> pre(n+1, vll(m+1, 0));",
      "for (int i = 1; i <= n; i++)",
      "    for (int j = 1; j <= m; j++)",
      "        pre[i][j] = grid[i][j] + pre[i-1][j] + pre[i][j-1] - pre[i-1][j-1];",
      "",
      "// sum of rectangle (r1,c1) to (r2,c2) 1-indexed:",
      "// pre[r2][c2] - pre[r1-1][c2] - pre[r2][c1-1] + pre[r1-1][c1-1]"
    ],
    "description": "2D Prefix Sum"
  },
  "DifferenceArray": {
    "prefix": "diffarray",
    "body": [
      "// Range update [l, r] += val in O(1), then rebuild in O(n)",
      "vll diff(n + 2, 0);",
      "auto range_add = [&](int l, int r, ll val) {",
      "    diff[l] += val;",
      "    diff[r+1] -= val;",
      "};",
      "// After all updates, rebuild:",
      "for (int i = 1; i < n; i++) diff[i] += diff[i-1];"
    ],
    "description": "Difference Array (range add)"
  },
  "InversePermutation": {
    "prefix": "invperm",
