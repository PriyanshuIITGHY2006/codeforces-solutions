  "BFSGrid": {
    "prefix": "bfsgrid",
    "body": [
      "vector<vi> dist(n, vi(m, -1));",
      "queue<pii> q;",
      "dist[${1:sr}][${2:sc}] = 0;",
      "q.push({${1:sr}, ${2:sc}});",
      "int dx[] = {0,0,1,-1};",
      "int dy[] = {1,-1,0,0};",
      "while (!q.empty()) {",
      "    auto [x, y] = q.front(); q.pop();",
      "    for (int d = 0; d < 4; d++) {",
      "        int nx = x + dx[d], ny = y + dy[d];",
      "        if (valid(nx,ny) && dist[nx][ny] == -1 && grid[nx][ny] != '#') {",
      "            dist[nx][ny] = dist[x][y] + 1;",
      "            q.push({nx, ny});",
      "        }",
      "    }",
      "}"
    ],
    "description": "BFS on Grid"
  },
  "FloodFill": {
    "prefix": "floodfill",
    "body": [
      "function<void(int,int)> flood = [&](int x, int y) {",
      "    if (!valid(x,y) || visited[x][y] || grid[x][y] != '${1:.}') return;",
      "    visited[x][y] = 1;",
      "    int dx[] = {0,0,1,-1};",
      "    int dy[] = {1,-1,0,0};",
      "    for (int d = 0; d < 4; d++) flood(x+dx[d], y+dy[d]);",
      "};"
    ],
    "description": "Flood Fill DFS"
  }
